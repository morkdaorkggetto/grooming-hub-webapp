# .env.example — Template variabili d'ambiente
# Copia questo file a .env e riempilo con i tuoi dati reali
# NON caricare .env su Git (è nel .gitignore)

# ========================================
# Supabase — Database e Autenticazione
# ========================================
# Ottieni questi valori dal dashboard Supabase:
# https://app.supabase.com/project/_/settings/api

# URL del progetto Supabase (es. https://xyz.supabase.co)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Chiave anonima Supabase (da Settings > API > anon public)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ========================================
# Ambiente Development
# ========================================
# Per testing locale con Supabase emulato

# Usa database locale (localStorage) per testing offline
# Rimuovi o metti a false per usare Supabase cloud
# VITE_USE_LOCAL=false

# URL locale di Supabase (se usi supabase start)
# VITE_SUPABASE_URL=http://localhost:54321
# VITE_SUPABASE_ANON_KEY=<chiave-generata-da-supabase-start>

# ========================================
# Note di Sicurezza
# ========================================
# • VITE_ prefix espone le variabili al frontend (ok per anon key)
# • Non mettere mai la service_role_key nel frontend
# • Mantieni .env fuori da Git
# • Usa variabili d'ambiente diverse per dev/prod
